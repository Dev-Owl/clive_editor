{
  "name": "@dev_owl/cliveedit",
  "version": "0.1.14",
  "description": "CliveEdit — A themeable WYSIWYG markdown editor component for Vue 3",
  "type": "module",
  "main": "./dist/cliveedit.umd.js",
  "module": "./dist/cliveedit.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/cliveedit.es.js",
      "require": "./dist/cliveedit.umd.js"
    },
    "./style.css": "./dist/cliveedit.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite --config vite.dev.config.ts",
    "build": "vue-tsc --noEmit && vite build && vue-tsc -p tsconfig.build.json",
    "build:only": "vite build",
    "build:pages": "vite build --config vite.pages.config.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "emoji-picker-element": ">=1.0.0",
    "shiki": ">=1.0.0",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "emoji-picker-element": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.3.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "emoji-picker-element": "^1.29.1",
    "jsdom": "^29.0.1",
    "lucide-vue-next": "^0.574.0",
    "markdown-it": "^14.1.1",
    "shiki": "^3.22.0",
    "turndown": "^7.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "vue": "^3.5.28",
    "vue-tsc": "^3.2.4"
  },
  "author": "Christian <christian.muehle@devowl.de>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dev-Owl/clive_editor.git"
  },
  "homepage": "https://github.com/Dev-Owl/clive_editor#readme",
  "bugs": "https://github.com/Dev-Owl/clive_editor/issues",
  "keywords": [
    "vue",
    "vue3",
    "markdown",
    "wysiwyg",
    "editor",
    "rich-text",
    "cliveedit"
  ],
  "publishConfig": {
    "access": "public"
  }
}
